{
  "name": "@certify/certfy-flow-service",
  "private": true,
  "version": "0.0.25",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prepare": "test \"$CI\" = \"true\" || husky install",
    "build": "vue-tsc -b && vite build",
    "test": "vitest run --environment jsdom --coverage",
    "test:ui": "vitest --environment jsdom --ui --coverage",
    "test:watch": "vitest --coverage",
    "preview": "vite preview",
    "prettier": "prettier --config .prettierrc --check \"src/**/*.{ts,tsx,js,jsx,vue,json,css,scss,md}\"",
    "prettier:fix": "prettier --config .prettierrc --write \"src/**/*.{ts,tsx,js,jsx,vue,json,css,scss,md}\"",
    "typecheck": "vue-tsc --noEmit --skipLibCheck",
    "lint:eslint": "eslint . --ext .ts,.tsx,.vue",
    "lint": "npm run typecheck && npm run lint:eslint",
    "lint:fix": "eslint . --ext .ts,.tsx,.vue --fix"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.9",
    "@sentry/vite-plugin": "^4.3.0",
    "@sentry/vue": "^10.17.0",
    "@vitejs/plugin-vue-jsx": "^5.1.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.45.0",
    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "@vueup/vue-quill": "^1.2.0",
    "axios": "^1.14.0",
    "codemirror": "^6.0.2",
    "husky": "^9.1.7",
    "pinia": "^3.0.4",
    "vsoft-design-system": "^1.1.233",
    "vue": "^3.5.13",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.0.8",
    "vue3-lottie": "^3.3.1"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@pinia/testing": "^0.1.7",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.2",
    "@types/testing-library__dom": "^7.5.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.1.4",
    "@vitest/eslint-plugin": "^1.2.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-no-loops": "^0.4.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^29.0.2",
    "msw": "^2.6.8",
    "prettier": "^3.4.2",
    "sass": "^1.32.7",
    "typescript": "^5.7.2",
    "uuid": "^11.1.0",
    "vite": "^7.0.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.1.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
